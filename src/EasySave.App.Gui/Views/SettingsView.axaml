<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EasySave.App.Gui.ViewModels"
             x:Class="EasySave.App.Gui.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="PARAMÈTRES" FontSize="18" FontWeight="Bold"/>

        <TextBlock Text="Langue :"/>
        <ComboBox ItemsSource="{Binding Languages}" 
                  SelectedItem="{Binding SelectedLanguage}" 
                  HorizontalAlignment="Stretch"/>

        <TextBlock Text="Format des Logs :"/>
        <ComboBox ItemsSource="{Binding LogFormats}" 
                  SelectedItem="{Binding SelectedLogFormat}" 
                  HorizontalAlignment="Stretch"/>

        <Separator/>

        <ToggleSwitch Content="Activer le chiffrement XOR" 
                      IsChecked="{Binding EncryptionEnabled}"/>
        
        <TextBlock Text="Clé secrète :"/>
        <TextBox Text="{Binding EncryptionKey}" 
                 IsEnabled="{Binding EncryptionEnabled}"
                 PasswordChar="*"/>
        
        <TextBlock Text="Extensions exclues du chiffrement (ex: .pdf, .txt) :" 
                   Margin="0,10,0,0"
                   IsEnabled="{Binding EncryptionEnabled}"/>

        <TextBox Text="{Binding ExcludedExtensions}" 
                 Watermark="Saisissez les extensions séparées par des virgules..."
                 IsEnabled="{Binding EncryptionEnabled}"
                 ToolTip.Tip="Les fichiers avec ces extensions ne seront pas chiffrés"/>

        <TextBlock Text="Note: Séparez les extensions par une virgule." 
                   FontSize="10" 
                   FontStyle="Italic"
                   Opacity="0.7"/>

        <Button Content="Enregistrer les modifications" 
                Command="{Binding SaveSettingsCommand}"
                HorizontalAlignment="Center"
                Padding="20,10"
                Classes="accent"/>
    </StackPanel>
</UserControl>