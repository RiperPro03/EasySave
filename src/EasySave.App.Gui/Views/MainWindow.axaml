<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EasySave.App.Gui.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1400"
        d:DesignHeight="800"
        x:Class="EasySave.App.Gui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Title="EasySave"
        Icon="avares://EasySave.App.Gui/Assets/easysave-logo.ico"
        MinWidth="1024"
        MinHeight="700"
        Background="#000000"
        TransparencyLevelHint="Blur">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Boutons sidebar -->
        <Style Selector="Button.sidebar-btn">
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        
        <Style Selector="Button.sidebar-btn.inactive:pointerover">
            <Setter Property="Background" Value="#25FFFFFF"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
        </Style>

        <Style Selector="Button.sidebar-btn.active">
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="BorderBrush" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Button.sidebar-btn.active:pointerover">
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="BorderBrush" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        
        <!-- Boutons d'action avec effet blur -->
        <Style Selector="Button.action-btn">
            <Setter Property="Padding" Value="20,11"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        
        <Style Selector="Button.action-btn.primary">
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        
        <Style Selector="Button.action-btn.primary:pointerover">
            <Setter Property="Background" Value="#0066DD"/>
        </Style>
        
        <Style Selector="Button.action-btn.secondary">
            <Setter Property="Background" Value="#28FFFFFF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#35FFFFFF"/>
        </Style>
        
        <Style Selector="Button.action-btn.secondary:pointerover">
            <Setter Property="Background" Value="#35FFFFFF"/>
        </Style>

        <!-- Cards avec glassmorphism -->
        <Style Selector="Border.glass-card">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="BorderBrush" Value="#28FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BoxShadow" Value="0 8 32 0 #40000000"/>
        </Style>
    </Window.Styles>

    <Border Background="#0F1419">

        <Grid RowDefinitions="70,*" Margin="0">

            <!-- ================= HEADER avec blur ================= -->
            <Border Grid.Row="0"
                    Background="#12FFFFFF"
                    BorderBrush="#20FFFFFF"
                    BorderThickness="0,0,0,1"
                    Margin="0"
                    Padding="32,0">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    
                    <!-- Logo -->
                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                Spacing="14"
                                VerticalAlignment="Center">
                        <Border Width="44" 
                                Height="44"
                                CornerRadius="11">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Color="#ffff" Offset="0"/>
                                    <GradientStop Color="#ffff" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Image Source="avares://EasySave.App.Gui/Assets/easysave-logo.ico"
                                   Width="40"
                                   Height="40"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="EasySave"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#FFFFFF"
                                       LetterSpacing="0.5"/>
                            <TextBlock Text="{Binding AppTagline}"
                                       FontSize="11"
                                       Foreground="#90FFFFFF"
                                       LetterSpacing="0.8"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Controls droite -->
                    <StackPanel Grid.Column="2" 
                                Orientation="Horizontal" 
                                Spacing="10"
                                VerticalAlignment="Center">
                        <Border Background="#18FFFFFF"
                                BorderBrush="#28FFFFFF"
                                BorderThickness="1"
                                Padding="12,6"
                                CornerRadius="8"
                                ToolTip.Tip="{Binding LogHubHealthTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="10"
                                        Height="10"
                                        CornerRadius="5"
                                        Background="{Binding LogHubHealthDotBrush}"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding LogHubHealthLabel}"
                                           Foreground="#E0FFFFFF"
                                           FontSize="12"
                                           FontWeight="Medium"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#18FFFFFF"
                                BorderBrush="#28FFFFFF"
                                BorderThickness="1"
                                Padding="12,6"
                                CornerRadius="8">
                            <TextBlock Text="{Binding AppVersion}"
                                       Foreground="#90FFFFFF"
                                       FontSize="12"
                                       FontWeight="Medium"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ================= MAIN CONTENT ================= -->
            <Grid Grid.Row="1" ColumnDefinitions="280,*" Margin="24,24,24,24">

                <!-- ================= SIDEBAR ================= -->
                <Border Grid.Column="0"
                        Classes="glass-card"
                        Padding="20"
                        Margin="0,0,24,0">
                    
                    <StackPanel Spacing="6">
                        
                        <!-- Section Navigation -->
                        <StackPanel Spacing="6" Margin="0,0,0,16">
                            <TextBlock Text="{Binding SidebarWorkspaceLabel}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#70FFFFFF"
                                       Margin="12,8,0,8"
                                       LetterSpacing="1.2"/>
                            
                            <Button Classes="sidebar-btn"
                                    Classes.active="{Binding IsDashboardActive}"
                                    Classes.inactive="{Binding IsDashboardInactive}"
                                    Command="{Binding ShowDashboardCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="24" Height="24" CornerRadius="6" Background="#20FFFFFF">
                                        <TextBlock Text="📊" FontSize="14" 
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding NavDashboardLabel}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="sidebar-btn"
                                    Classes.active="{Binding IsJobsActive}"
                                    Classes.inactive="{Binding IsJobsInactive}"
                                    Command="{Binding ShowJobsCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="24" Height="24" CornerRadius="6" Background="#20FFFFFF">
                                        <TextBlock Text="📁" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding NavBackupJobsLabel}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="sidebar-btn"
                                    Classes.active="{Binding IsExecutionActive}"
                                    Classes.inactive="{Binding IsExecutionInactive}"
                                    Command="{Binding ShowExecutionCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="24" Height="24" CornerRadius="6" Background="#20FFFFFF">
                                        <TextBlock Text="▶" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding NavLiveExecutionLabel}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="sidebar-btn"
                                    Classes.active="{Binding IsLogsActive}"
                                    Classes.inactive="{Binding IsLogsInactive}"
                                    Command="{Binding ShowLogsCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="24" Height="24" CornerRadius="6" Background="#20FFFFFF">
                                        <TextBlock Text="📝" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding NavLogsLabel}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Divider avec gradient -->
                        <Border Height="1" Margin="8,8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                                    <GradientStop Color="#30FFFFFF" Offset="0.5"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Section System -->
                        <StackPanel Spacing="6" Margin="0,16,0,0">
                            <TextBlock Text="{Binding SidebarSystemLabel}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#70FFFFFF"
                                       Margin="12,0,0,8"
                                       LetterSpacing="1.2"/>

                            <Button Classes="sidebar-btn"
                                    Classes.active="{Binding IsSettingsActive}"
                                    Classes.inactive="{Binding IsSettingsInactive}"
                                    Command="{Binding ShowSettingsCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="24" Height="24" CornerRadius="6" Background="#20FFFFFF">
                                        <TextBlock Text="⚙" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding NavSettingsLabel}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="sidebar-btn"
                                    Classes.active="{Binding IsAboutActive}"
                                    Classes.inactive="{Binding IsAboutInactive}"
                                    Command="{Binding ShowAboutCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="24" Height="24" CornerRadius="6" Background="#20FFFFFF">
                                        <TextBlock Text="ℹ" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding NavAboutLabel}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Stats card en bas -->
                        <!-- <Border Background="#15FFFFFF" -->
                        <!--         BorderBrush="#25FFFFFF" -->
                        <!--         BorderThickness="1" -->
                        <!--         CornerRadius="12" -->
                        <!--         Padding="16" -->
                        <!--         Margin="0,24,0,0"> -->
                        <!--     <StackPanel Spacing="8"> -->
                        <!--         <TextBlock Text="STORAGE" -->
                        <!--                    FontSize="10" -->
                        <!--                    FontWeight="Bold" -->
                        <!--                    Foreground="#70FFFFFF" -->
                        <!--                    LetterSpacing="1"/> -->
                        <!--         <TextBlock Text="127.4 GB" -->
                        <!--                    FontSize="24" -->
                        <!--                    FontWeight="Bold" -->
                        <!--                    Foreground="#FFFFFF"/> -->
                        <!--         <TextBlock Text="Used of 500 GB" -->
                        <!--                    FontSize="12" -->
                        <!--                    Foreground="#80FFFFFF"/> -->
                        <!--         ~1~ Progress bar @1@ -->
                        <!--         <Border Height="4"  -->
                        <!--                 Background="#20FFFFFF" -->
                        <!--                 CornerRadius="2" -->
                        <!--                 Margin="0,4,0,0"> -->
                        <!--             <Border Width="80" -->
                        <!--                     Height="4" -->
                        <!--                     Background="#0A84FF" -->
                        <!--                     CornerRadius="2" -->
                        <!--                     HorizontalAlignment="Left"/> -->
                        <!--         </Border> -->
                        <!--     </StackPanel> -->
                        <!-- </Border> -->

                    </StackPanel>
                </Border>

                <!-- ================= CONTENT AREA ================= -->
                <Grid Grid.Column="1" RowDefinitions="Auto,*">
                    
                    <!-- Header de page avec actions -->
                    <Grid Grid.Row="0" 
                          ColumnDefinitions="*,Auto"
                          Margin="0,0,0,28">
                        
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="{Binding CurrentPageTitle}"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="#FFFFFF"
                                       LetterSpacing="0.5"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="14"
                                       Foreground="#80FFFFFF"/>
                        </StackPanel>
                        
                        <!-- <StackPanel Grid.Column="1" -->
                        <!--             Orientation="Horizontal" -->
                        <!--             Spacing="12" -->
                        <!--             VerticalAlignment="Center"> -->
                        <!-- </StackPanel> -->
                    </Grid>

                    <!-- Main content card -->
                    <Border Grid.Row="1"
                            Classes="glass-card"
                            Padding="0">
                            
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="32">
                                <ContentControl Content="{Binding CurrentView}" />
                            </ScrollViewer>
                    </Border>

                </Grid>

            </Grid>

        </Grid>
    </Border>
</Window>

