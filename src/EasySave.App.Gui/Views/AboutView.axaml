<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EasySave.App.Gui.ViewModels"
             xmlns:res="using:EasySave.Core.Resources"
             x:Class="EasySave.App.Gui.Views.AboutView"
             x:DataType="vm:AboutViewModel"
             HorizontalAlignment="Stretch">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" 
                    HorizontalAlignment="Left" 
                    MaxWidth="800">
            
            <Border Background="#18FFFFFF" 
                    BorderBrush="#28FFFFFF" 
                    BorderThickness="1" 
                    CornerRadius="12" 
                    Padding="20"
                    HorizontalAlignment="Left">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding ProductName}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{x:Static res:Strings.About_Intro}" 
                               FontSize="13" 
                               Foreground="#B0FFFFFF" 
                               TextWrapping="Wrap"
                               MaxWidth="600"/> </StackPanel>
            </Border>

            <TextBlock Text="{x:Static res:Strings.Guide_Title}" FontSize="12" FontWeight="Bold" Foreground="#70FFFFFF" LetterSpacing="1"/>
            
            <Border Background="#12FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="12" Padding="20" HorizontalAlignment="Left">
                <StackPanel Spacing="20">
                    <StackPanel Spacing="5">
                        <TextBlock Text="{x:Static res:Strings.Step1_Title}" FontWeight="Bold" Foreground="#0A84FF"/>
                        <TextBlock Text="{x:Static res:Strings.Step1_Desc}" FontSize="13" Foreground="#D0FFFFFF" TextWrapping="Wrap"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="5">
                        <TextBlock Text="{x:Static res:Strings.Step2_Title}" FontWeight="Bold" Foreground="#0A84FF"/>
                        <TextBlock Text="{x:Static res:Strings.Step2_Desc}" FontSize="13" Foreground="#D0FFFFFF" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="{x:Static res:Strings.Step3_Title}" FontWeight="Bold" Foreground="#0A84FF"/>
                        <TextBlock Text="{x:Static res:Strings.Step3_Desc}" FontSize="13" Foreground="#D0FFFFFF" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="{x:Static res:Strings.Team_Title}" FontSize="12" FontWeight="Bold" Foreground="#70FFFFFF" LetterSpacing="1"/>
            
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="👤 Christopher ASIN" Margin="0,0,20,5" Foreground="White" FontSize="13"/>
                <TextBlock Text="👤 Shayna ROSIER" Margin="0,0,20,5" Foreground="White" FontSize="13"/>
                <TextBlock Text="👤 Mathis VOGEL" Margin="0,0,20,5" Foreground="White" FontSize="13"/>
                <TextBlock Text="👤 Maxime LANDEAU" Margin="0,0,20,5" Foreground="White" FontSize="13"/>
            </WrapPanel>

            <Separator Background="#20FFFFFF" HorizontalAlignment="Stretch"/>
            
            <StackPanel Spacing="5" HorizontalAlignment="Left">
                <TextBlock Text="{x:Static res:Strings.Gui_About_GitHubLabel}" FontWeight="Medium" Foreground="#70FFFFFF" FontSize="12"/>
                <TextBlock Text="https://github.com/RiperPro03/EasySave" 
                           Foreground="#0A84FF" 
                           TextWrapping="Wrap"/>
            </StackPanel>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
