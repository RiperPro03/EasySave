@startuml EasySave_App_Gui_MVVM_Focus

skinparam backgroundColor white
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 70
skinparam ranksep 120
left to right direction
skinparam packageStyle rectangle

skinparam class {
    BackgroundColor<<ViewModel>> #E8F5E9
    BorderColor<<ViewModel>> #2E7D32
    BackgroundColor<<View>> #F3E5F5
    BorderColor<<View>> #6A1B9A
    BackgroundColor<<Model>> #E3F2FD
    BorderColor<<Model>> #1565C0
    BackgroundColor<<Base>> #ECEFF1
    BorderColor<<Base>> #455A64
}

title Class Diagram - EasySave.App.Gui (Views + ViewModels + UI items)

package "ViewModels" {
  abstract class ViewModelBase <<Base>>

  class MainWindowViewModel <<ViewModel>> {
    +AppVersion
    +StatusMessage
    +CurrentPageTitle
    +CurrentView
    +ActiveTab
    +Dispose()
  }

  class DashboardViewModel <<ViewModel>> {
    +RecentActivities
    +TotalJobs
    +ActiveJobs
    +InactiveJobs
    +LastBackup
    +SystemStatus
    +RefreshJobSummary()
    +NotifyLogWritten()
    +Dispose()
  }

  class JobsViewModel <<ViewModel>> {
    +Jobs
    +LastError
    +CreateRequested
    +EditRequested
    +JobsChanged
    +CreateFromEditor(...)
    +UpdateFromEditor(...)
  }

  class JobEditorViewModel <<ViewModel>> {
    +JobId
    +Name
    +SourcePath
    +TargetPath
    +SelectedType
    +IsActive
    +CanSave
    +IsEditMode
    +CloseRequested
    +CreateNew()
    +FromJob(...)
  }

  class ExecutionViewModel <<ViewModel>> {
    +Jobs
    +LastError
    +RefreshJobs()
    +Dispose()
  }

  class LogsViewModel <<ViewModel>> {
    +Logs
    +RefreshLogs()
  }

  class SettingsViewModel <<ViewModel>> {
    +EncryptionEnabled
    +EncryptionKey
    +SelectedLanguage
    +SelectedLogFormat
    +ExtensionsToEncrypt
    +BusinessSoftwareProcessName
    +SaveSettings()
    +RefreshLocalization()
  }

  class AboutViewModel <<ViewModel>> {
    +ProductName
    +Version
  }
}

package "UI Model Items" {
  class ExecutionJobItem <<Model>> {
    +JobId
    +JobName
    +Status
    +ProgressPercentage
    +CanPlayPause
    +CanStop
    +CanStart
    +UpdateDefinition(...)
    +UpdateFromState(...)
  }

  class LogEntryItem <<Model>> {
    +Entry
    +Sections
  }

  class LogSection <<Model>> {
    +Title
    +Fields
  }

  class LogField <<Model>> {
    +Label
    +Value
  }

  class RecentActivityItem <<Model>> {
    +Title
    +Subtitle
    +Timestamp
  }
}

package "Used Services (App)" {
  class JobService <<Base>>
  class BackupService <<Base>>
  class SettingsService <<Base>>
  class LogReaderService <<Base>>
  class AppLogService <<Base>>
  class Loc <<Base>>
}

package "Views" {
  class MainWindow <<View>> {
    +MainWindow()
    +OnClosed(...)
  }
  class DashboardView <<View>>
  class JobsView <<View>>
  class JobEditorDialog <<View>>
  class ExecutionView <<View>>
  class LogsView <<View>>
  class SettingsView <<View>>
  class AboutView <<View>>
}

' Base inheritance
MainWindowViewModel --|> ViewModelBase
DashboardViewModel --|> ViewModelBase
JobsViewModel --|> ViewModelBase
JobEditorViewModel --|> ViewModelBase
ExecutionViewModel --|> ViewModelBase
LogsViewModel --|> ViewModelBase
SettingsViewModel --|> ViewModelBase
AboutViewModel --|> ViewModelBase

' Main composition (navigation shell)
MainWindow --> MainWindowViewModel : DataContext
MainWindowViewModel *-- DashboardViewModel
MainWindowViewModel *-- JobsViewModel
MainWindowViewModel *-- ExecutionViewModel
MainWindowViewModel *-- LogsViewModel
MainWindowViewModel *-- SettingsViewModel
MainWindowViewModel *-- AboutViewModel

' View <-> ViewModel bindings
DashboardView --> DashboardViewModel : binds
JobsView --> JobsViewModel : binds
JobEditorDialog --> JobEditorViewModel : binds
ExecutionView --> ExecutionViewModel : binds
LogsView --> LogsViewModel : binds
SettingsView --> SettingsViewModel : binds
AboutView --> AboutViewModel : binds

' UI flow helpers
JobsView ..> JobEditorDialog : opens
JobsViewModel ..> JobEditorViewModel : create/edit flow

' ViewModel -> UI model items
DashboardViewModel --> RecentActivityItem : exposes
ExecutionViewModel --> ExecutionJobItem : exposes
LogsViewModel --> LogEntryItem : exposes
LogEntryItem --> LogSection : contains
LogSection --> LogField : contains

' ViewModel -> services (concrete app services only)
MainWindowViewModel ..> JobService : uses
MainWindowViewModel ..> BackupService : uses
MainWindowViewModel ..> SettingsService : uses
MainWindowViewModel ..> AppLogService : listens
MainWindowViewModel ..> Loc : localization

DashboardViewModel ..> JobService : uses
DashboardViewModel ..> BackupService : listens
DashboardViewModel ..> LogReaderService : reads

JobsViewModel ..> JobService : uses
ExecutionViewModel ..> JobService : uses
ExecutionViewModel ..> BackupService : controls
LogsViewModel ..> LogReaderService : reads
SettingsViewModel ..> SettingsService : applies
SettingsViewModel ..> Loc : localization

@enduml
