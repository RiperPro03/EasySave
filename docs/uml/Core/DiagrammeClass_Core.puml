@startuml EasySave_Core_Classes

' ============================================
' CONFIGURATION
' ============================================
skinparam backgroundColor white
skinparam shadowing false
skinparam linetype polyline
skinparam nodesep 200
skinparam ranksep 200

skinparam class {
    BackgroundColor<<Model>> #C8E6C9
    BorderColor<<Model>> #388E3C
    BackgroundColor<<DTO>> #E1F5FE
    BorderColor<<DTO>> #0277BD
    BackgroundColor<<Interface>> #E8F5E9
    BorderColor<<Interface>> #2E7D32
    BackgroundColor<<Event>> #FFF3E0
    BorderColor<<Event>> #EF6C00
}

title Diagramme de classes - EasySave.Core (Domain + DTO + Interfaces + Events)
left to right direction
skinparam packageStyle rectangle

' ============================================
' PACKAGE: EasySave.Core
' ============================================
package "EasySave.Core" {

  package "Enums" {
    enum BackupType <<Model>> {
      Full
      Differential
    }

    enum JobStatus <<Model>> {
      Idle
      Running
      Paused
      Completed
      Error
    }

    enum Language <<Model>> {
      English
      French
    }
  }

  package "Common" {
    class Guard <<Model>> {
      {static} +string NotNullOrWhiteSpace(string? value, string paramName)
    }

    class Localization <<Model>> {
      {static} +CultureInfo GetCulture(Language language)
    }
  }

  package "Models" {
    class BackupJob <<Model>> {
      +string Id
      +string Name
      +string SourcePath
      +string TargetPath
      +BackupType Type
      +bool IsActive
      +DateTime CreatedAt
      +DateTime? LastRun
      __
      +BackupJob(id: string, name: string, sourcePath: string, targetPath: string, type: BackupType, isActive: bool = true, createdAtUtc: DateTime? = null, lastRunUtc: DateTime? = null)
      +void Enable()
      +void Disable()
      +void MarkExecuted(nowUtc: DateTime? = null)
      +void UpdateDefinition(name: string, sourcePath: string, targetPath: string, type: BackupType)
      +string ToString()
    }

    class AppConfig <<Model>> {
      +Language Language
      +string LogDirectory
      +LogFormat LogFormat
      __
      -AppConfig(language: Language, logDirectory: string, logFormat: LogFormat)
      +{static} AppConfig LoadDefaults()
      +void ChangeLanguage(Language language)
      +void UpdateLogDirectory(string logDirectory)
      +void ChangeLogFormat(LogFormat logFormat)
      -{static} string GetDefaultLogDirectory()
    }
  }

  package "DTO" {
    class AppStateDto <<DTO>> {
      +DateTime GeneratedAtUtc
      +int TotalJobs
      +JobStatus GlobalStatus
      +List<string> ActiveJobIds
      +List<JobStateDto> Jobs
      __
      +AppStateDto()
    }

    class BackupJobDto <<DTO>> {
      +string? Id
      +string? Name
      +string? SourcePath
      +string? TargetPath
      +string? Type
      +bool IsActive
      +DateTime CreatedAt
      +DateTime? LastRun
      __
      +BackupJobDto()
      +bool IsValid()
      +BackupJob ToModel()
      +{static} BackupJobDto FromModel(job: BackupJob)
    }

    class BackupResultDto <<DTO>> {
      +bool Success
      +string Message
      +int FilesProcessed
      +long TotalBytesProcessed
      +int CopiedCount
      +int SkippedCount
      +int ErrorCount
      +TimeSpan Duration
      +List<string> Errors
      __
      +BackupResultDto()
    }

    class JobStateDto <<DTO>> {
      +string JobId
      +string JobName
      +JobStatus Status
      +string? CurrentSourceFile
      +string? CurrentTargetFile
      +long TotalFiles
      +long FilesProcessed
      +long TotalSizeBytes
      +long SizeProcessedBytes
      +int ProgressPercentage
      +long RemainingFiles
      +long RemainingSizeBytes
      +DateTime LastActionTimestampUtc
      +string? ErrorMessage
      __
      +JobStateDto()
    }

    class LogEntryDto <<DTO>> {
      +DateTime TimestampUtc
      +string JobName
      +string SourcePath
      +string TargetPath
      +long FileSizeBytes
      +double TransferTimeMs
      +string Status
      +string? ErrorMessage
      __
      +LogEntryDto()
    }

    class ResultDto <<DTO>> {
      +bool Success
      +string Message
      +string? ErrorCode
      __
      +{static} ResultDto Ok(message: string)
      +{static} ResultDto Fail(message: string, errorCode: string? = null)
    }
  }

  package "Events" {
    class JobStateChangedEventArgs <<Event>> {
      +JobStateDto State
      __
      +JobStateChangedEventArgs(state: JobStateDto)
    }
  }

  package "Interfaces" {
    interface IBackupEngine <<Interface>> {
      +event EventHandler<JobStateChangedEventArgs>? StateChanged
      +BackupResultDto Run(BackupJob job)
    }

    interface IBackupCopyStrategy <<Interface>> {
      +bool ShouldCopy(string sourcePath, string targetPath)
    }

    interface IBackupService <<Interface>> {
      +event EventHandler<JobStateChangedEventArgs>? StateChanged
      +BackupResultDto Run(BackupJob job)
    }

    interface IFileSystem <<Interface>> {
      +bool DirectoryExists(string path)
      +void CreateDirectory(string path)
      +IEnumerable<string> EnumerateFiles(string path, bool recursive)
      +bool FileExists(string path)
      +long GetFileSize(string path)
      +DateTime GetLastWriteTimeUtc(string path)
      +void CopyFile(string sourcePath, string targetPath, bool overwrite)
    }

    interface IJobRepository <<Interface>> {
      +IReadOnlyList<BackupJob> GetAll()
      +BackupJob? GetById(string id)
      +void Add(BackupJob job)
      +void Update(BackupJob job)
      +void Remove(string id)
    }

    interface IJobService <<Interface>> {
      +IReadOnlyList<BackupJob> GetAll()
      +BackupJob? GetById(string id)
      +void Create(string id, string name, string sourcePath, string targetPath, BackupType type, bool isActive = true)
      +void Update(string id, string name, string sourcePath, string targetPath, BackupType type, bool isActive)
      +void MarkExecuted(string id, DateTime? nowUtc = null)
      +void Delete(string id)
    }

    interface IPathProvider <<Interface>> {
      +string LogsPath
      +string StatePath
      +string ConfigPath
      +void EnsureDirectoriesCreated()
    }

    interface IStateWriter <<Interface>> {
      +void Write(AppStateDto state)
    }
  }
}

