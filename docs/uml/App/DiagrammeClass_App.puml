@startuml EasySave_App_Classes

' ============================================
' CONFIGURATION
' ============================================
skinparam backgroundColor white
skinparam shadowing false
skinparam linetype polyline
skinparam nodesep 50
skinparam ranksep 2200

skinparam class {
    BackgroundColor<<Service>> #FFF3E0
    BorderColor<<Service>> #F57C00
    BackgroundColor<<Repository>> #F3E5F5
    BorderColor<<Repository>> #7B1FA2
    BackgroundColor<<Strategy>> #E3F2FD
    BorderColor<<Strategy>> #1565C0
}

title Diagramme de classes - EasySave.App (Implementations)
left to right direction
skinparam packageStyle rectangle

' ============================================
' PACKAGE: EasySave.App
' ============================================
package "EasySave.App" {

  package "Services" {
    class BackupEngine <<Service>> {
      -ILogger<LogEntryDto>? _logger
      __
      +BackupEngine(logDirectory: string? = null, logFormat: LogFormat = LogFormat.Json)
      +event EventHandler<JobStateChangedEventArgs>? StateChanged
      +BackupResultDto Run(BackupJob job)
      -void ExecuteBackup(IReadOnlyList<string> files, string sourceRoot, string targetRoot, IBackupCopyStrategy strategy, BackupResultDto result, JobStateDto state)
      -{static} void CopyFile(string sourcePath, string targetPath)
      -void WriteSummaryLog(BackupJob job, BackupResultDto result)
      -JobStateDto CreateInitialState(BackupJob job)
      -void InitializeTotals(JobStateDto state, int totalFiles, long totalSizeBytes)
      -void UpdateProgressState(JobStateDto state, string sourcePath, string targetPath, long fileSize, bool incrementProcessed)
      -void UpdateTerminalState(JobStateDto state, JobStatus status, string? errorMessage)
      -void PublishState(JobStateDto state)
      -{static} int CalculateProgress(JobStateDto state)
    }

    class BackupService <<Service>> {
      -IBackupEngine _backupEngine
      -IJobService _jobService
      -IStateWriter _stateWriter
      -Dictionary<string, JobStateDto> _jobStates
      -object _stateLock
      -string? _logDirectory
      -Func<LogFormat> _logFormatProvider
      -LogFormat _currentLogFormat
      __
      +event EventHandler<JobStateChangedEventArgs>? StateChanged
      +BackupService(jobService: IJobService, logDirectory: string? = null, stateWriter: IStateWriter? = null, pathProvider: IPathProvider? = null, logFormat: LogFormat? = null, logFormatProvider: Func<LogFormat>? = null)
      +BackupResultDto Run(BackupJob job)
      -void OnEngineStateChanged(object? sender, JobStateChangedEventArgs e)
      -void InitializeSnapshot()
      -void SyncJobs()
      -void WriteSnapshot()
      -{static} JobStatus ComputeGlobalStatus(IReadOnlyList<JobStateDto> states)
      -{static} JobStateDto CreateIdleState(BackupJob job)
      -{static} JobStateDto CopyState(JobStateDto state)
      -void EnsureEngine()
      -IBackupEngine CreateEngine(LogFormat format)
    }

    class JobService <<Service>> {
      -IJobRepository _jobRepository
      __
      +JobService(pathProvider: IPathProvider)
      +IReadOnlyList<BackupJob> GetAll()
      +BackupJob? GetById(string id)
      +void Create(string id, string name, string sourcePath, string targetPath, BackupType type, bool isActive = true)
      +void Update(string id, string name, string sourcePath, string targetPath, BackupType type, bool isActive)
      +void MarkExecuted(string id, DateTime? nowUtc = null)
      +void Delete(string id)
    }

    class PathProvider <<Service>> {
      -string _basePath
      __
      +string LogsPath
      +string StatePath
      +string ConfigPath
      +void EnsureDirectoriesCreated()
    }

    class StateWriter <<Service>> {
      -IPathProvider _pathProvider
      -JsonSerializerOptions _options
      __
      +StateWriter(pathProvider: IPathProvider)
      +void Write(AppStateDto state)
    }

    class DifferentialCopyStrategy <<Strategy>> {
      +bool ShouldCopy(string sourcePath, string targetPath)
      __
      -{static} byte[] ComputeHash(string path)
    }

    class FullCopyStrategy <<Strategy>> {
      +bool ShouldCopy(string sourcePath, string targetPath)
    }
  }

  package "Repositories" {
    class JobRepository <<Repository>> {
      -IPathProvider _pathProvider
      -List<BackupJob> _jobs
      -string _jobsFilePath
      -{static} int MaxJobs = 5
      __
      +JobRepository(pathProvider: IPathProvider)
      +IReadOnlyList<BackupJob> GetAll()
      +BackupJob? GetById(string id)
      +void Add(BackupJob job)
      +void Remove(string id)
      +void Update(BackupJob updatedJob)
      -List<BackupJob> LoadJobs()
      -void SaveJobs()
    }

    class AppConfigRepository <<Repository>> {
      -{static} string ConfigFileName = "setting.json"
      -IPathProvider _pathProvider
      -string _configFilePath
      -JsonSerializerOptions _options
      __
      +AppConfigRepository(pathProvider: IPathProvider)
      +AppConfig Load()
      +void Save(AppConfig config)
    }
  }
}

