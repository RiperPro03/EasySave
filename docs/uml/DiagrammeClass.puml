@startuml EasySave_v1_Classes

' ============================================
' CONFIGURATION
' ============================================
skinparam backgroundColor white
skinparam shadowing false
skinparam linetype polyline
skinparam nodesep 200
skinparam ranksep 200

skinparam class {
    BackgroundColor<<Model>> #C8E6C9
    BorderColor<<Model>> #388E3C
    BackgroundColor<<DTO>> #E1F5FE
    BorderColor<<DTO>> #0277BD
    BackgroundColor<<Interface>> #E8F5E9
    BorderColor<<Interface>> #2E7D32
    BackgroundColor<<Service>> #FFF3E0
    BorderColor<<Service>> #F57C00
    BackgroundColor<<Repository>> #F3E5F5
    BorderColor<<Repository>> #7B1FA2
    BackgroundColor<<Console>> #FFE0B2
    BorderColor<<Console>> #E65100
    BackgroundColor<<EasyLog>> #FFF9C4
    BorderColor<<EasyLog>> #F9A825
    BackgroundColor<<Command>> #E3F2FD
    BorderColor<<Command>> #1565C0
}

title Diagramme de classes - EasySave v1.0 (Core + Console alignes au code)\n' Layout
left to right direction
skinparam packageStyle rectangle

' Force package ordering
"EasySave.Core" -[hidden]-> "EasySave.App"
"EasySave.App" -[hidden]-> "EasySave.EasyLog"
"EasySave.Core" -[hidden]-> "EasySave.App.Console"\n

' ============================================
' PACKAGE: EasySave.Core
' ============================================
package "EasySave.Core" {

  package "Enums" {
    enum BackupType <<Model>> {
      Full
      Differential
    }

    enum JobStatus <<Model>> {
      Idle
      Running
      Paused
      Completed
      Error
    }

    enum Language <<Model>> {
      English
      French
    }
  }

  package "Common" {
    class Guard <<Model>> {
      {static} +string NotNullOrWhiteSpace(string value, string paramName)
    }

    class Localization <<Model>> {
      {static} +CultureInfo GetCulture(Language language)
    }
  }

  package "Models" {
    class BackupJob <<Model>> {
      +string Id
      +string Name
      +string SourcePath
      +string TargetPath
      +BackupType Type
      +bool IsActive
      +DateTime CreatedAt
      +DateTime LastRun
      __
      +BackupJob(id: string, name: string, sourcePath: string, targetPath: string, type: BackupType, isActive: bool, createdAtUtc: DateTime, lastRunUtc: DateTime)
      +void Enable()
      +void Disable()
      +void MarkExecuted(nowUtc: DateTime)
      +void UpdateDefinition(name: string, sourcePath: string, targetPath: string, type: BackupType)
      +string ToString()
    }

    class AppConfig <<Model>> {
      +Language Language
      +string LogDirectory
      __
      -AppConfig(language: Language, logDirectory: string)
      +{static} AppConfig LoadDefaults()
      +void ChangeLanguage(Language language)
      +void UpdateLogDirectory(string logDirectory)
      -{static} string GetDefaultLogDirectory()
    }
  }

  package "DTO" {
    class BackupJobDto <<DTO>> {
      +string Id
      +string Name
      +string SourcePath
      +string TargetPath
      +string Type
      +bool IsActive
      +DateTime CreatedAt
      +DateTime LastRun
      __
      +BackupJobDto()
      +bool IsValid()
      +BackupJob ToModel()
      +{static} BackupJobDto FromModel(job: BackupJob)
    }

    class BackupResultDto <<DTO>> {
      +bool Success
      +string Message
      +int FilesProcessed
      +long TotalBytesProcessed
      +TimeSpan Duration
      +List Errors
      __
      +BackupResultDto()
    }

    class JobStateDto <<DTO>> {
      +string JobId
      +string JobName
      +JobStatus Status
      +string CurrentFile
      +long TotalFilesToCopy
      +long TotalFilesCopied
      +long TotalSizeBytes
      +long SizeCopiedBytes
      +int ProgressPercentage
      +DateTime StartTimeUtc
      +DateTime EndTimeUtc
      +string ErrorMessage
      __
      +JobStateDto()
    }

    class LogEntryDto <<DTO>> {
      +DateTime TimestampUtc
      +string JobName
      +string SourcePath
      +string TargetPath
      +long FileSizeBytes
      +double TransferTimeMs
      +string Status
      +string ErrorMessage
      __
      +LogEntryDto()
    }

    class ResultDto <<DTO>> {
      +bool Success
      +string Message
      +string ErrorCode
      __
      +{static} ResultDto Ok(message: string)
      +{static} ResultDto Fail(message: string, errorCode: string)
    }
  }

  package "Interfaces" {
    interface IBackupEngine <<Interface>> {
      +BackupResultDto Run(BackupJob job)
    }

    interface IFileSystem <<Interface>> {
      +bool DirectoryExists(string path)
      +void CreateDirectory(string path)
      +IEnumerable EnumerateFiles(string path, bool recursive)
      +bool FileExists(string path)
      +long GetFileSize(string path)
      +DateTime GetLastWriteTimeUtc(string path)
      +void CopyFile(string sourcePath, string targetPath, bool overwrite)
    }

    interface IJobRepository <<Interface>> {
      +IReadOnlyList GetAll()
      +BackupJob GetById(string id)
      +void Add(BackupJob job)
      +void Update(BackupJob job)
      +void Remove(string id)
    }

    interface IStateWriter <<Interface>> {
      +void Write(JobStateDto state)
    }
  }
}

' ============================================
' PACKAGE: EasySave.EasyLog
' ============================================
package "EasySave.EasyLog" {

  interface ILoggerT <<EasyLog>> {
    +bool Write(T entry)
  }

  interface ILogSerializer <<EasyLog>> {
    +string Serialize(object entry)
    +string FileExtension
  }

  interface ILogWriter <<EasyLog>> {
    +bool Write(string filepath, string message)
  }

  class LogOptions <<EasyLog>> {
    +string LogDirectory
    +LogFormat Format
    +bool UseSafeLogger
  }

  enum LogFormat <<EasyLog>> {
    Json
    Xml
  }

  class LoggerFactory <<EasyLog>> {
    {static} +ILoggerT Create(LogOptions options)
  }
}

' ============================================
' PACKAGE: EasySave.App (cible v1 - a implementer)
' ============================================
package "EasySave.App" {

  package "Services" {
    class BackupEngine <<Service>> {
      +BackupResultDto Run(BackupJob job)
      -void CopyDirectory(BackupJob job, BackupResultDto result)
      -bool ShouldCopyFile(BackupType type, string sourceFile, string targetFile)
      -string ResolveTargetFilePath(string sourceFile, string targetPath)
      -void EnsureDirectoryExists(string directory)
    }

    interface IJobService <<Service>> {
      +IReadOnlyList GetAll()
      +BackupJob GetById(string id)
      +void Create(string id, string name, string sourcePath, string targetPath, BackupType type, bool isActive)
      +void Update(string id, string name, string sourcePath, string targetPath, BackupType type, bool isActive)
      +void Delete(string id)
    }

    class JobService <<Service>> {
      -EasySave.Core.Interfaces.IJobRepository _jobRepository
      __
      +JobService(jobRepository: IJobRepository)
      +IReadOnlyList GetAll()
      +BackupJob GetById(string id)
      +void Create(string id, string name, string sourcePath, string targetPath, BackupType type, bool isActive)
      +void Update(string id, string name, string sourcePath, string targetPath, BackupType type, bool isActive)
      +void Delete(string id)
    }

    class BackupService <<Service>> {
      -EasySave.Core.Interfaces.IJobRepository _jobRepository
      -EasySave.Core.Interfaces.IBackupEngine _engine
      -EasySave.Core.Interfaces.IFileSystem _fileSystem
      -EasySave.EasyLog.ILoggerT _logger
      -EasySave.Core.Interfaces.IStateWriter _stateWriter
      -int _maxJobs
      __
      +BackupService(jobRepo: IJobRepository, engine: IBackupEngine, fileSystem: IFileSystem, logger: ILoggerT, stateWriter: IStateWriter, maxJobs: int)
      +ResultDto CreateJob(BackupJob job)
      +ResultDto UpdateJob(BackupJob job)
      +ResultDto DeleteJob(string jobId)
      +IReadOnlyList GetAllJobs()
      +BackupJob GetJob(string jobId)
      +BackupResultDto RunJob(string jobId)
      +IReadOnlyList RunSequentialJobs()
    }

    class CommandLineParser <<Service>> {
      +List ParseArguments(string[] args)
      +bool IsValidCommand(string command)
    }
  }

  package "Commands" {
    interface ICommand <<Command>> { 
        +void Execute() 
    }
    interface ICommandT <<Command>> { 
        +void Execute() 
    }

    class CreateJobCommand <<Command>> {
      -BackupService _service
      -BackupJob _job
      __
      +CreateJobCommand(BackupService service, BackupJob job)
      +ResultDto Execute()
    }

    class UpdateJobCommand <<Command>> {
      -BackupService _service
      -BackupJob _job
      __
      +UpdateJobCommand(BackupService service, BackupJob job)
      +ResultDto Execute()
    }

    class DeleteJobCommand <<Command>> {
      -BackupService _service
      -string _jobId
      __
      +DeleteJobCommand(BackupService service, string jobId)
      +ResultDto Execute()
    }

    class RunJobCommand <<Command>> {
      -BackupService _service
      -string _jobId
      __
      +RunJobCommand(BackupService service, string jobId)
      +BackupResultDto Execute()
    }

    class RunAllJobsCommand <<Command>> {
      -BackupService _service
      __
      +RunAllJobsCommand(BackupService service)
      +IReadOnlyList Execute()
    }
  }

  package "Repositories" {
    class JobRepository <<Repository>> {
      -List _jobs
      -int MaxJobs
      __
      +IReadOnlyList GetAll()
      +BackupJob GetById(string id)
      +void Add(BackupJob job)
      +void Update(BackupJob job)
      +void Remove(string id)
    }

    class ConfigRepository <<Repository>> {
      -string _configFilePath
      __
      +ConfigRepository(string filePath)
      +AppConfig Load()
      +void Save(AppConfig config)
    }

    class StateWriterRepository <<Repository>> {
      -string _stateFilePath
      -EasySave.Core.Interfaces.IFileSystem _fileSystem
      __
      +StateWriterRepository(string filePath, IFileSystem fileSystem)
      +void Write(JobStateDto state)
    }
  }

}

' ============================================
' PACKAGE: EasySave.App.Console (code actuel)
' ============================================
package "EasySave.App.Console" {

  class Program <<Console>> { 
    {static} +void Main(string[] args) 
  }

  package "Controllers" {
    class MenuController <<Console>> {
      +MenuController(ConsoleView view, ConsoleInput input, JobController jobController, BackupController backupController, SettingsController settingsController)
      +void Run()
    }

    class JobController <<Console>> {
      -EasySave.App.Services.IJobService _jobService
      -JobView _jobView
      -ConsoleView _consoleView
      __
      +JobController(IJobService jobService, JobView jobView, ConsoleView consoleView)
      +void RunMenu()
      +void ListJobs()
      +void CreateJob()
      +void UpdateJob()
      +void DeleteJob()
    }

    class BackupController <<Console>> {
      -EasySave.Core.Interfaces.IBackupEngine _backupEngine
      -BackupView _backupView
      -ConsoleView _consoleView
      -ArgsParser _argsParser
      __
      +BackupController(IBackupEngine backupEngine, BackupView backupView, ConsoleView consoleView, ArgsParser argsParser)
      +void RunMenu()
      +void RunFromArgs(string rawArgs)
      +BackupResultDto RunJobById(int id, bool waitForKey)
      +void RunAll()
    }

    class SettingsController <<Console>> {
      +SettingsController(AppConfig config, ConsoleView consoleView, ConsoleInput input)
      +void Run()
    }
  }

  package "Input" {
    class ConsoleInput <<Console>> {
      +int ReadInt(string prompt)
      +string ReadNonEmptyString(string prompt)
      +int ReadChoice(string prompt, IEnumerable validChoices)
    }

    class ArgsParser <<Console>> {
      +IReadOnlyList Parse(string rawArgs)
    }
  }

  package "Views" {
    class ConsoleView <<Console>> {
      +void Clear()
      +void ShowHeader()
      +void ShowMenu(string title, IEnumerable options)
      +void ShowError(string message)
      +void ShowSuccess(string message)
      +void ShowInfo(string message)
      +void WaitForKey()
    }

    class JobView <<Console>> {
      +void ShowJobMenu()
      +int ReadMenuChoice()
      +string AskJobName()
      +string AskSourcePath()
      +string AskTargetPath()
      +BackupType AskBackupType()
      +void ShowJobs(IReadOnlyList jobs)
      +string AskJobId()
      +int AskJobFieldToEdit()
      +bool AskJobActiveState()
    }

    class BackupView <<Console>> {
      +void ShowBackupMenu()
      +int ReadMenuChoice()
      +void ShowJobs(IReadOnlyList jobs)
      +int AskJobId()
      +void ShowRunStart(BackupJob job)
      +void ShowRunEnd(BackupResultDto result)
      +void ShowBatchResult(IReadOnlyList results)
    }
  }

  package "Models" {
    class MenuOption <<Console>> { 
        +int Id; +string Label 
    }
  }
}

