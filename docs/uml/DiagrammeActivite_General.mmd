flowchart TD
  %% Diagramme d activite general - lancement app et execution d un job

  start([Debut])
  init[Demarrage de l application]
  loadConfig[Charger la configuration]
  setCulture[Appliquer la langue / culture]
  initServices[Initialiser services et controleurs]
  argsCheck{Arguments fournis ?}

  start --> init --> loadConfig --> setCulture --> initServices --> argsCheck

  %% Mode arguments
  argsCheck --|Oui|--> parseArgs[Parser les arguments]
  parseArgs --> argsValid{Arguments valides ?}
  argsValid --|Non|--> showArgsError[Afficher erreur] --> fin([Fin])

  argsValid --|Oui|--> loopIds{{Pour chaque id}}
  loopIds --> getJob[Charger le job]
  getJob --> jobFound{Job trouve ?}
  jobFound --|Non|--> showJobError[Afficher job introuvable] --> loopIds
  jobFound --|Oui|--> runJob[Executer le job]
  runJob --> showResult[Afficher resultat] --> loopIds
  loopIds --> batchSummary[Afficher resume batch] --> fin

  %% Mode menu interactif
  argsCheck --|Non|--> showMenu[Afficher menu principal]
  showMenu --> chooseAction{Choix utilisateur}
  chooseAction --|Lancer un job|--> selectJob[Selectionner un job] --> runJobUI[Executer le job] --> showResultUI[Afficher resultat] --> showMenu
  chooseAction --|Gerer les jobs|--> manageJobs[Creer / Modifier / Supprimer] --> showMenu
  chooseAction --|Parametres|--> settings[Modifier langue ou format log] --> showMenu
  chooseAction --|Quitter|--> fin

  %% Execution d un job (vue globale)
  runJob --> engineStart[BackupService vers BackupEngine]
  engineStart --> checkSource[Verifier dossier source]
  checkSource --> sourceOk{Source valide ?}
  sourceOk --|Non|--> jobError[Marquer erreur et logger] --> jobDone[Retourner resultat]
  sourceOk --|Oui|--> selectStrategy[Choisir strategie Full ou Diff]
  selectStrategy --> processFiles[Parcourir fichiers et copier si besoin]
  processFiles --> finalize[Finaliser statut et logger] --> jobDone
  jobDone --> showResult
