flowchart TD
  %% General activity diagram - V3 (GUI + live execution behavior)
  %% Natural language, aligned with async run + state/log driven monitoring

  start([Start])
  openApp[Open the GUI application]
  loadConfig[Load user configuration]
  applyLang[Apply selected language]
  initApp[Initialize services and screens]
  showDashboard[Show dashboard]
  nav{User action}

  start --> openApp --> loadConfig --> applyLang --> initApp --> showDashboard --> nav

  %% -------------------- MAIN NAVIGATION --------------------
  nav -- Manage jobs --> jobsList[Show job list]
  jobsList --> jobsAction{What to do?}
  jobsAction -- Create --> jobCreate[Create a new job]
  jobsAction -- Edit --> jobEdit[Edit an existing job]
  jobsAction -- Delete --> jobDelete[Delete a job]
  jobsAction -- Enable/Disable --> jobToggle[Change active status]
  jobCreate --> saveJobs[Validate and save jobs]
  jobEdit --> saveJobs
  jobDelete --> saveJobs
  jobToggle --> saveJobs
  saveJobs --> showDashboard

  nav -- Settings --> settings[Change language, logging, encryption and business software settings]
  settings --> saveSettings[Save settings]
  saveSettings --> showDashboard

  nav -- View logs --> openLogs[Open logs screen - local or remote depending on mode]
  openLogs --> showDashboard

  nav -- Live execution --> openExecution[Open execution screen]
  openExecution --> runMode{Execution action}
  runMode -- Start one job --> pickOne[Select one job]
  runMode -- Start all runnable jobs --> runAll[Launch run all workflow]
  runMode -- Pause / Resume / Stop --> liveControl[Control a running or paused job]
  liveControl --> refreshExec[Refresh live state from state updates]
  refreshExec --> openExecution

  %% -------------------- RUN ALL (GUI) --------------------
  runAll --> globalCheck{Business software running before sequence?}
  globalCheck -- Yes --> globalBlocked[Show sequence blocked message] --> openExecution
  globalCheck -- No --> collectActions[Build list of paused jobs to resume and jobs to start]
  collectActions --> anyAction{Anything to do?}
  anyAction -- No --> noRunnable[Show no runnable job message] --> openExecution
  anyAction -- Yes --> resumePaused[Resume paused jobs first]
  resumePaused --> loopStartAll[Start runnable jobs one by one]
  loopStartAll --> startLaunchOnly[Each start returns immediately - async launch result]
  startLaunchOnly --> openExecution

  %% -------------------- RUN ONE (ASYNC START) --------------------
  pickOne --> runOne[Request start for selected job]
  runOne --> jobActive{Job is active?}
  jobActive -- No --> inactiveMsg[Show inactive job skipped message] --> runReturn
  jobActive -- Yes --> preStartCheck{Business software running?}
  preStartCheck -- Yes --> startBlocked[Show blocked at start message] --> runReturn
  preStartCheck -- No --> duplicateCheck{Already running or stopping?}
  duplicateCheck -- Yes --> alreadyRunning[Show already running message] --> runReturn
  duplicateCheck -- No --> publishRunning[Publish Running state snapshot]
  publishRunning --> startBackground[Start backup in background]
  startBackground --> launchResult[Return immediate launch result]
  launchResult --> runReturn

  %% -------------------- BACKGROUND EXECUTION (ENGINE) --------------------
  startBackground --> engineStart[Background engine starts the job]
  engineStart --> engineStartCheck{Business software still running?}
  engineStartCheck -- Yes --> engineBlocked[Write logs + publish Error state] --> engineEnd
  engineStartCheck -- No --> sourceCheck{Source folder available?}
  sourceCheck -- No --> sourceError[Write summary + publish Error state] --> engineEnd
  sourceCheck -- Yes --> chooseStrategy[Choose full or differential copy strategy]
  chooseStrategy --> enumerateFiles[List files and compute totals]
  enumerateFiles --> publishInitProgress[Publish initial progress state]
  publishInitProgress --> filesLoop{Next file?}

  filesLoop -- No --> finalize[Write summary log and publish final state]
  filesLoop -- Yes --> autoPauseCheck{Business software detected?}

  %% V3 behavior: auto pause/resume instead of stopping the job
  autoPauseCheck -- Yes --> autoPause[Publish Paused state + log auto-pause]
  autoPause --> waitBusinessClose[Wait until business software is closed]
  waitBusinessClose --> autoResume[Publish Running state + log auto-resume]
  autoResume --> copyDecision
  autoPauseCheck -- No --> copyDecision{Should this file be copied?}

  copyDecision -- No --> skipFile[Skip file and log skip]
  skipFile --> updateProgress[Publish progress state]

  copyDecision -- Yes --> prepareTarget[Ensure target folder exists]
  prepareTarget --> copyFile[Copy file]
  copyFile --> logTransfer[Log file transfer]
  logTransfer --> cryptoNeeded{Encryption required for this file?}

  cryptoNeeded -- No --> updateProgress
  cryptoNeeded -- Yes --> cryptoAvailable{CryptoSoft available?}
  cryptoAvailable -- No --> cryptoSkip[Log encryption skipped - fallback] --> updateProgress
  cryptoAvailable -- Yes --> encryptFile[Encrypt copied file]
  encryptFile --> encryptResult{Encryption succeeded?}
  encryptResult -- No --> cryptoError[Add encryption error and log failure] --> updateProgress
  encryptResult -- Yes --> logCryptoOk[Log encryption success] --> updateProgress

  updateProgress --> stopRequested{Stop requested by user?}
  stopRequested -- Yes --> stoppedByUser[Write summary + publish Error state - stopped] --> engineEnd
  stopRequested -- No --> filesLoop

  finalize --> markFinal{Errors found?}
  markFinal -- No --> completeOk[Mark job completed]
  markFinal -- Yes --> completeWithErrors[Mark job completed with errors]
  completeOk --> engineEnd
  completeWithErrors --> engineEnd

  engineEnd[Background execution ends and marks job executed] --> monitorLoop

  %% -------------------- LIVE MONITORING --------------------
  runReturn --> showExecScreen[Show execution screen with launch result]
  showExecScreen --> monitorLoop{Wait for next user action or state update}
  monitorLoop -- State update received --> refreshFromState[Refresh job cards from state snapshot/event]
  refreshFromState --> openExecution
  monitorLoop -- User controls job --> liveControl
  monitorLoop -- Back to dashboard --> showDashboard
  monitorLoop -- Quit --> finishNode([End])

  nav -- Quit --> finishNode
