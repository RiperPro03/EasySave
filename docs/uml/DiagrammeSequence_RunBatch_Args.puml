@startuml EasySave_RunBatch_Args

' ============================================
' CONFIGURATION
' ============================================
skinparam shadowing false
skinparam dpi 170
skinparam backgroundColor #FFFFFF

skinparam sequence {
  MessageAlign center
  ArrowColor #2F3A4A
  ArrowThickness 1
  LifeLineBorderColor #B7C0CE
  LifeLineBackgroundColor #F7F9FC

  ParticipantBorderColor #2F3A4A
  ParticipantBackgroundColor #EEF3FF
  ParticipantFontColor #1C2A3A
  ParticipantFontStyle bold

  ActorBorderColor #2F3A4A
  ActorBackgroundColor #FFF4E5

  BoxBorderColor #9FB1C9
  BoxBackgroundColor #F7F9FC

  GroupBorderColor #9FB1C9
  GroupBackgroundColor #F7F9FC
}

title <b>EasySave</b>\n<i>Sequence lancement batch via arguments (V2)</i>

' -------------------- ACTEURS / PARTICIPANTS --------------------
actor Utilisateur #FFF4E5

participant "<b>Program</b>" as Program #EEF3FF
participant "<b>BackupController</b>" as BackupController #E9F7EF
participant "<b>ArgsParser</b>" as ArgsParser #F3E8FF
participant "<b>JobService</b>" as JobService #E6F4FF
participant "<b>BackupService</b>" as BackupService #FFE9EC
participant "<b>BusinessSoftwareDetector</b>" as Detector #FFF8E1
participant "<b>BackupEngine</b>" as BackupEngine #F3E8FF
participant "<b>IBackupCopyStrategy</b>" as Strategy #E6F4FF
participant "<b>ICryptoService</b>\n(CryptoSoftProcess / NoEncryption)" as Crypto #E8F5E9
participant "<b>Logger</b>" as Logger #FCE4EC
participant "<b>Systeme de fichiers</b>" as FS #E0F2F1
participant "<b>BackupView</b>" as BackupView #E6F4FF
participant "<b>ConsoleView</b>" as ConsoleView #F7F9FC

' -------------------- FLUX --------------------
== Demarrage ==
Utilisateur -> Program : Lance l application avec arguments (ex: "1;2;3" ou "1-3")
Program -> BackupController : RunFromArgs(rawArgs)

== Analyse des arguments ==
BackupController -> ArgsParser : Parse(rawArgs)

alt Arguments invalides
  ArgsParser --> BackupController : Exception (format/range/empty)
  BackupController -> ConsoleView : ShowError(ex.Message)
  BackupController --> Program : Fin
else Arguments valides
  ArgsParser --> BackupController : ids

  == Controle global avant batch ==
  BackupController -> BackupService : CanStartSequence()
  BackupService -> Detector : IsRunning(processName)
  alt Logiciel metier actif
    BackupService --> BackupController : false + reason
    BackupController -> ConsoleView : ShowError(reason)
    BackupController --> Program : Fin
  else Sequence autorisee
    BackupService --> BackupController : true

    loop Pour chaque id
      == Controle avant chaque job ==
      BackupController -> BackupService : CanStartSequence()
      BackupService -> Detector : IsRunning(processName)
      alt Logiciel metier detecte en cours de batch
        BackupService --> BackupController : false + reason
        BackupController -> ConsoleView : ShowError(reason)
        break
      else Etape autorisee
        BackupService --> BackupController : true

        BackupController -> JobService : GetById(id.ToString())
        alt Job introuvable
          JobService --> BackupController : null
          BackupController -> ConsoleView : ShowError("Job with ID {id} not found.")
        else Job trouve
          JobService --> BackupController : job
          BackupController -> BackupView : ShowRunStart(job)

          == Execution interne du meme service ==
          BackupController -> BackupService : Run(job)

          BackupService -> Detector : IsRunning(processName)
          alt Logiciel metier detecte (Run)
            BackupService -> Logger : Log "job.start.blocked.businesssoftware"
            BackupService --> BackupController : BackupResultDto (erreur blocage)
          else Job actif et autorise
            BackupService -> BackupEngine : Run(job)

            BackupEngine -> Detector : ValidateNotRunning(processName)
            alt Logiciel metier detecte (Engine)
              BackupEngine -> Logger : Log blocage + summary
              BackupEngine --> BackupService : BackupResultDto (erreur)
              BackupService --> BackupController : BackupResultDto
            else Execution backup
              loop Pour chaque fichier
                BackupEngine -> Strategy : ShouldCopy(source, target)
                alt Doit copier
                  BackupEngine -> FS : CopyFile(source, target)
                  opt Chiffrement requis
                    BackupEngine -> Crypto : EncryptFileAsync(target, key)
                    Crypto --> BackupEngine : encryptionTimeMs / code
                    alt Echec chiffrement
                      BackupEngine -> Logger : Log "file.encrypted" (failure)
                    else Chiffrement OK
                      BackupEngine -> Logger : Log "file.encrypted" (success)
                    end
                  end
                else Ne doit pas copier
                  BackupEngine -> Logger : Log "file.skipped"
                end

                BackupEngine -> Detector : IsRunning(processName)
                alt Logiciel metier detecte en cours
                  BackupEngine -> Logger : Log "job.stopped.businesssoftware"
                  break
                end
              end

              BackupEngine -> Logger : WriteSummaryLog(job.summary)
              BackupEngine --> BackupService : BackupResultDto
              BackupService --> BackupController : BackupResultDto
            end
          end

          BackupController -> BackupView : ShowRunEnd(result)
          BackupController -> BackupController : results.Add(result)
        end
      end
    end

    == Resume ==
    BackupController -> BackupView : ShowBatchResult(results)
    note right of BackupView
      Si results est vide:
      affiche "No jobs executed".
    end note
  end
end

@enduml
