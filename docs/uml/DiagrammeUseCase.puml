@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

skinparam actor {
  BackgroundColor #E8F5E9
  BorderColor #2F3A4A
}

skinparam usecase {
  BackgroundColor #FFF3E0
  BorderColor #2F3A4A
  FontStyle bold
}

title EasySave – Use Case v2.0

actor Utilisateur as User
actor "Logiciel Metier" as BusinessApp
actor "CryptoSoft (Externe)" as CryptoSoft

rectangle "EasySave (V2)" {

  (Gerer les jobs) as UC_JOBS
  (Changer la langue\nFR / EN) as UC_LANG
  (Choisir format logs\nJSON / XML) as UC_LOG_FMT

  (Lancer sauvegarde) as UC_RUN

  (Suivre la progression) as UC_PROGRESS
  (Consulter l'etat des jobs\nstate.json) as UC_STATE
  (Consulter les logs) as UC_LOGS

  (Bloquer si logiciel metier actif) as UC_BLOCK
  (Chiffrer certains fichiers) as UC_CRYPTO
  (Configurer extensions a chiffrer) as UC_CFG_EXT
  (Configurer logiciel metier surveille) as UC_CFG_APP
}

' --- Liens utilisateur
User --> UC_JOBS
User --> UC_LANG
User --> UC_LOG_FMT
User --> UC_RUN
User --> UC_PROGRESS
User --> UC_STATE
User --> UC_LOGS
User --> UC_CFG_EXT
User --> UC_CFG_APP

' --- INCLUDE (vert)
UC_RUN .[#008000]> UC_PROGRESS : <<include>>
UC_RUN .[#008000]> UC_STATE    : <<include>>
UC_RUN .[#008000]> UC_LOGS     : <<include>>

' --- EXTEND (rouge)
UC_RUN ..[#FF0000]> UC_BLOCK  : <<extend>>
UC_RUN ..[#FF0000]> UC_CRYPTO : <<extend>>

' --- Acteurs externes
UC_BLOCK --> BusinessApp
UC_CRYPTO --> CryptoSoft

@enduml
