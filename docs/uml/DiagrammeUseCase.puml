@startuml
left to right direction

skinparam usecase {
    BackgroundColor #FFE4C4
    BorderColor black
    ArrowColor black
}

title EasySave - Use case (V1.1)

actor Utilisateur

package "EasySave" {
    usecase "Sauvegarder la configuration" as UC_Config
    usecase "Choisir le format du log (JSON/XML)" as UC_LogFormat
    usecase "Changer la langue (FR/EN)" as UC_Langue
    usecase "Valider les données du job" as UC_Valider
    usecase "Sauvegarder la liste des jobs" as UC_SauvegarderJobs
    usecase "Gérer les jobs (CRUD)" as UC_Gerer
    usecase "Consulter le résultat" as UC_Consulter
    usecase "Configurer l'application" as UC_ConfigApp
    usecase "Journaliser l'exécution (log)" as UC_Journal
    usecase "Mettre ŕ jour l'état global (state.json)" as UC_State
    usecase "Exécuter un job" as UC_Executer
    usecase "Valider les arguments" as UC_Args
    usecase "Exécuter des jobs par arguments (CLI)" as UC_ExecArgs
    usecase "Exécuter tous les jobs" as UC_ExecTous
}

' Relations principales
Utilisateur --> UC_Gerer
Utilisateur --> UC_Consulter
Utilisateur --> UC_ConfigApp
Utilisateur --> UC_Executer
Utilisateur --> UC_Langue

' Include systématique
UC_Gerer --> UC_Valider : <<include>>
UC_Gerer --> UC_SauvegarderJobs : <<include>>
UC_Executer --> UC_State : <<include>>
UC_Executer --> UC_Args : <<include>>

' Extend pour actions secondaires/log
UC_Executer ..> UC_Journal : <<extend>>
UC_Langue ..> UC_Config : <<extend>>
UC_ConfigApp ..> UC_Config : <<include>>
UC_Executer --> UC_ExecArgs : <<include>>
UC_Executer --> UC_ExecTous : <<include>>

' Include optionnel pour logs
UC_SauvegarderJobs --> UC_LogFormat : <<include>>
@enduml
