@startuml EasySave_UseCase_V2

left to right direction
skinparam backgroundColor white
skinparam shadowing false
skinparam linetype ortho

skinparam actor {
  BackgroundColor #E8F5E9
  BorderColor #2F3A4A
}

skinparam usecase {
  BackgroundColor #FFF3E0
  BorderColor #2F3A4A
  FontStyle bold
}

title EasySave – Use case (V2.0)

' =========================
' ACTEURS
' =========================
actor "Utilisateur" as User
actor "Logiciel Métier\n(Externe)" as BusinessApp
actor "CryptoSoft\n(Externe)" as CryptoSoft

' =========================
' SYSTEME
' =========================
rectangle "EasySave v2.0" {

  package "Gestion des travaux" {
    (Gérer les jobs\nCRUD illimités) as UC_CRUD
    (Valider les données) as UC_ValidateJob
    (Sauvegarder les jobs) as UC_SaveJobs
  }

  package "Exécution des sauvegardes" {
    (Exécuter un job) as UC_RunOne
    (Exécuter tous les jobs) as UC_RunAll
    (Mettre à jour state.json) as UC_State
    (Journaliser dans log) as UC_Log
    (Détecter logiciel métier) as UC_BusinessCheck
    (Chiffrer via CryptoSoft) as UC_Crypto
    (Consulter résultat) as UC_Result
  }

  package "Configuration" {
    (Changer langue FR/EN) as UC_Lang
    (Choisir format log\nJSON/XML) as UC_LogFormat
    (Définir extensions à chiffrer\net logiciel métier) as UC_DefineCrypto
    (Sauvegarder configuration) as UC_SaveConfig
  }
}

' =========================
' LIENS UTILISATEUR
' =========================
User --> UC_CRUD
User --> UC_RunOne
User --> UC_RunAll
User --> UC_Result

User --> UC_Lang
User --> UC_LogFormat
User --> UC_DefineCrypto

' =========================
' ACTEURS EXTERNES
' =========================
UC_BusinessCheck --> BusinessApp
UC_Crypto --> CryptoSoft

' =========================
' RELATIONS UML
' =========================

' ---- INCLUDE
UC_CRUD ..> UC_ValidateJob : <<include>>
UC_CRUD ..> UC_SaveJobs    : <<include>>

UC_RunAll ..> UC_RunOne : <<include>>

UC_RunOne ..> UC_State         : <<include>>
UC_RunOne ..> UC_Log           : <<include>>
UC_RunOne ..> UC_BusinessCheck : <<include>>
UC_RunOne ..> UC_Crypto        : <<extend>>

UC_Lang ..> UC_SaveConfig : <<include>>
UC_LogFormat ..> UC_SaveConfig : <<include>>
UC_DefineCrypto ..> UC_SaveConfig : <<include>>

' ---- EXTEND
UC_Result ..> UC_RunOne : <<extend>>

@enduml