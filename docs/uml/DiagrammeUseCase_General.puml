@startuml EasySave_UseCase_V3

left to right direction
skinparam backgroundColor white
skinparam shadowing false
skinparam linetype ortho

skinparam actor {
  BackgroundColor #E8F5E9
  BorderColor #2F3A4A
}

skinparam usecase {
  BackgroundColor #FFF3E0
  BorderColor #2F3A4A
  FontStyle bold
}

title EasySave - Use case (V3.0)

' =========================
' ACTEURS
' =========================
actor "Utilisateur" as User
actor "Logiciel metier\n(Externe)" as BusinessApp
actor "CryptoSoft\n(Externe)" as CryptoSoft
actor "LogHub Server\n(Docker / WebSocket)" as LogHub

' =========================
' SYSTEME
' =========================
rectangle "EasySave v3.0" {

  package "Gestion des jobs" {
    (Gerer les jobs\nCRUD illimites) as UC_CRUD
    (Valider les donnees job) as UC_ValidateJob
    (Definir extensions\nprioritaires par job) as UC_JobPriority
    (Sauvegarder les jobs) as UC_SaveJobs
  }

  package "Execution et pilotage V3" {
    (Piloter un job\ncommandes d execution) as UC_ControlOne
    (Piloter plusieurs jobs\ncommandes globales) as UC_ControlMany

    (Executer un job) as UC_RunOne
    (Controler execution en cours\netat + commandes runtime) as UC_RuntimeControl
    (Gerer protection logiciel metier\nblocage + auto-pause/reprise) as UC_BusinessProtection
    (Appliquer priorisation et\ncontrole de flux) as UC_PriorityFlow
    (Journaliser les evenements) as UC_Log
    (Envoyer logs au serveur\ncentralise) as UC_LogServerWrite
    (Chiffrer via CryptoSoft) as UC_Crypto
  }

  package "Supervision" {
    (Suivre l'etat en temps reel) as UC_LiveState
    (Consulter les logs / activite) as UC_ViewLogs
    (Lire logs locaux) as UC_ReadLocalLogs
    (Lire logs centralises) as UC_ReadServerLogs
  }

  package "Configuration" {
    (Changer langue FR/EN) as UC_Lang
    (Choisir format log\nJSON/XML) as UC_LogFormat
    (Choisir mode de stockage log\nLocal / Server / Mixte) as UC_LogStorageMode
    (Configurer serveur de logs\nhost/port LogHub) as UC_LogServerConfig
    (Definir chiffrement\nextensions + cle) as UC_CryptoConfig
    (Definir logiciel metier\na surveiller) as UC_BusinessConfig
    (Definir seuil gros fichiers\ncontrole de flux) as UC_LargeFileThreshold
    (Sauvegarder configuration) as UC_SaveConfig
  }
}

' =========================
' LIENS UTILISATEUR
' =========================
User --> UC_CRUD

User --> UC_ControlOne
User --> UC_ControlMany

User --> UC_LiveState
User --> UC_ViewLogs

User --> UC_Lang
User --> UC_LogFormat
User --> UC_LogStorageMode
User --> UC_LogServerConfig
User --> UC_CryptoConfig
User --> UC_BusinessConfig
User --> UC_LargeFileThreshold

' =========================
' ACTEURS EXTERNES
' =========================
UC_BusinessProtection --> BusinessApp
UC_Crypto --> CryptoSoft
UC_LogServerWrite --> LogHub
UC_ReadServerLogs --> LogHub

' =========================
' RELATIONS UML
' =========================

' ---- Gestion des jobs
UC_CRUD ..> UC_ValidateJob : <<include>>
UC_CRUD ..> UC_JobPriority : <<include>>
UC_CRUD ..> UC_SaveJobs    : <<include>>

' ---- Pilotage utilisateur
UC_RunOne ..> UC_ControlOne  : <<extend>>
UC_RunOne ..> UC_ControlMany : <<extend>>

' ---- Execution interne V3
UC_RunOne ..> UC_RuntimeControl     : <<include>>
UC_RunOne ..> UC_BusinessProtection : <<include>>
UC_RunOne ..> UC_PriorityFlow       : <<include>>
UC_RunOne ..> UC_Log                : <<include>>
UC_Crypto ..> UC_RunOne             : <<extend>>

UC_LogServerWrite ..> UC_Log : <<extend>>

' ---- Supervision
UC_ReadLocalLogs  ..> UC_ViewLogs : <<extend>>
UC_ReadServerLogs ..> UC_ViewLogs : <<extend>>

' ---- Configuration
UC_Lang               ..> UC_SaveConfig : <<include>>
UC_LogFormat          ..> UC_SaveConfig : <<include>>
UC_LogStorageMode     ..> UC_SaveConfig : <<include>>
UC_LogServerConfig    ..> UC_SaveConfig : <<include>>
UC_CryptoConfig       ..> UC_SaveConfig : <<include>>
UC_BusinessConfig     ..> UC_SaveConfig : <<include>>
UC_LargeFileThreshold ..> UC_SaveConfig : <<include>>

@enduml
