@startuml EasySave_RunJob_General

' ============================================
' CONFIGURATION
' ============================================
skinparam shadowing false
skinparam dpi 170
skinparam backgroundColor #FFFFFF

skinparam sequence {
  MessageAlign center
  ArrowColor #2F3A4A
  ArrowThickness 1
  LifeLineBorderColor #B7C0CE
  LifeLineBackgroundColor #F7F9FC

  ParticipantBorderColor #2F3A4A
  ParticipantBackgroundColor #EEF3FF
  ParticipantFontColor #1C2A3A
  ParticipantFontStyle bold

  ActorBorderColor #2F3A4A
  ActorBackgroundColor #FFF4E5

  BoxBorderColor #9FB1C9
  BoxBackgroundColor #F7F9FC

  GroupBorderColor #9FB1C9
  GroupBackgroundColor #F7F9FC
}

title <b>EasySave</b>\n<i>Sequence de lancement d un job (V2: blocage metier + CryptoSoft)</i>

' -------------------- ACTEURS / PARTICIPANTS --------------------
actor Utilisateur #FFF4E5

participant "<b>Interface</b>\n(Console ou GUI)" as UI #EEF3FF
participant "<b>JobService</b>" as JobService #E9F7EF
participant "<b>JobRepository</b>" as JobRepository #F3E8FF
participant "<b>BackupService</b>" as BackupService #E6F4FF
participant "<b>BusinessSoftwareDetector</b>" as Detector #FFF8E1
participant "<b>BackupEngine</b>" as BackupEngine #FFE9EC
participant "<b>IBackupCopyStrategy</b>" as Strategy #F7F9FC
participant "<b>ICryptoService</b>\n(CryptoSoftProcess / NoEncryption)" as Crypto #E8F5E9
participant "<b>StateWriter</b>" as StateWriter #FFFDE7
participant "<b>Logger</b>" as Logger #FCE4EC
participant "<b>Systeme de fichiers</b>" as FS #E0F2F1

' -------------------- FLUX --------------------
== Selection du job ==
Utilisateur -> UI : Choisit un job a executer
UI -> JobService : GetById(jobId)
JobService -> JobRepository : Charge le job
JobRepository --> JobService : BackupJob
JobService --> UI : BackupJob

== Validation de lancement ==
UI -> BackupService : Run(job)

alt Job inactif
  BackupService -> Logger : Log "job.skipped"
  BackupService --> UI : Resultat "Job is inactive and was skipped"
else Job actif
  BackupService -> Detector : IsRunning(processName config)
  alt Logiciel metier detecte (avant start)
    BackupService -> Logger : Log "job.start.blocked.businesssoftware"
    BackupService --> UI : Resultat erreur (blocage metier)
  else Aucun blocage metier
    BackupService -> BackupService : SyncJobs + set state Running
    BackupService -> StateWriter : Write(snapshot)
    BackupService -> BackupEngine : Run(job)

    == Controle metier dans le moteur ==
    BackupEngine -> Detector : ValidateNotRunning(processName config)
    alt Logiciel metier detecte
      BackupEngine -> Logger : Log blocage + summary
      BackupEngine -> BackupService : StateChanged(Error)
      BackupService -> StateWriter : Write(snapshot)
      BackupEngine --> BackupService : Resultat erreur
      BackupService -> JobService : MarkExecuted(job.Id)
      BackupService --> UI : Retourne resultat
    else Execution autorisee
      BackupEngine -> FS : Verifie dossier source

      alt Dossier source manquant
        BackupEngine -> Logger : Log summary erreur
        BackupEngine -> BackupService : StateChanged(Error)
        BackupService -> StateWriter : Write(snapshot)
        BackupEngine --> BackupService : Resultat erreur
        BackupService -> JobService : MarkExecuted(job.Id)
        BackupService --> UI : Retourne resultat
      else Dossier source present
        BackupEngine -> BackupEngine : Choisit Strategy (Full/Differential)
        BackupEngine -> FS : Enumere fichiers + calcule totaux
        BackupEngine -> BackupService : StateChanged(Running init)
        BackupService -> StateWriter : Write(snapshot)

        loop Pour chaque fichier
          BackupEngine -> Strategy : ShouldCopy(source, target)

          alt Doit copier
            BackupEngine -> FS : EnsureTargetDirectory + CopyFile
            BackupEngine -> Logger : Log transfert

            opt Fichier eligibile chiffrement\n(encryption enabled + key + extension)
              alt CryptoSoft disponible
                BackupEngine -> Crypto : EncryptFileAsync(target, key)
                Crypto --> BackupEngine : encryptionTimeMs / code erreur

                alt Echec chiffrement
                  BackupEngine -> BackupEngine : Ajoute erreur au resultat
                  BackupEngine -> Logger : Log "file.encrypted" (failure)
                else Chiffrement OK
                  BackupEngine -> Logger : Log "file.encrypted" (success)
                end
              else CryptoSoft absent (fallback)
                BackupEngine -> Logger : Log "crypto.fallback"
                BackupEngine -> Logger : Log "file.encryption.skipped"
              end
            end
          else Ne doit pas copier
            BackupEngine -> BackupEngine : Incremente skipped
            BackupEngine -> Logger : Log "file.skipped"
          end

          BackupEngine -> BackupService : StateChanged(progress)
          BackupService -> StateWriter : Write(snapshot)

          BackupEngine -> Detector : IsRunning(processName config)
          alt Logiciel metier detecte en cours de run
            BackupEngine -> Logger : Log "job.stopped.businesssoftware"
            BackupEngine -> BackupEngine : Ajoute erreur puis break
          end
        end

        == Finalisation ==
        BackupEngine -> Logger : WriteSummaryLog(job.summary)
        BackupEngine -> BackupService : StateChanged(Completed/Error)
        BackupService -> StateWriter : Write(snapshot)
        BackupEngine --> BackupService : BackupResultDto
        BackupService -> JobService : MarkExecuted(job.Id)
        BackupService --> UI : Retourne resultat final
      end
    end
  end
end

UI -> Utilisateur : Affiche le resultat

@enduml
