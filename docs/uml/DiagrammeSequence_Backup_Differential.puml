@startuml EasySave_Backup_Differential

' ============================================
' CONFIGURATION
' ============================================
skinparam shadowing false
skinparam dpi 170
skinparam backgroundColor #FFFFFF

skinparam sequence {
  MessageAlign center
  ArrowColor #2F3A4A
  ArrowThickness 1
  LifeLineBorderColor #B7C0CE
  LifeLineBackgroundColor #F7F9FC

  ParticipantBorderColor #2F3A4A
  ParticipantBackgroundColor #EEF3FF
  ParticipantFontColor #1C2A3A
  ParticipantFontStyle bold

  ActorBorderColor #2F3A4A
  ActorBackgroundColor #FFF4E5

  BoxBorderColor #9FB1C9
  BoxBackgroundColor #F7F9FC

  GroupBorderColor #9FB1C9
  GroupBackgroundColor #F7F9FC
}

title <b>EasySave</b>\n<i>Sequence sauvegarde differentielle (V3: Run async + pause auto logiciel metier)</i>

actor Utilisateur #FFF4E5
participant "<b>Interface</b>\n(Console ou GUI)" as UI #EEF3FF
participant "<b>BackupService</b>" as BackupService #E9F7EF
participant "<b>StateWriter</b>" as StateWriter #FFFDE7
participant "<b>ThreadPool</b>\n(Task.Run)" as ThreadPool #F7F9FC
participant "<b>BackupEngine</b>" as BackupEngine #F3E8FF
participant "<b>BusinessSoftwareDetector</b>" as Detector #FFF8E1
participant "<b>DifferentialCopyStrategy</b>" as Strategy #E6F4FF
participant "<b>ICryptoService</b>\n(CryptoSoft / NoEncryption)" as Crypto #E8F5E9
participant "<b>Logger</b>" as Logger #F7F9FC
participant "<b>Systeme de fichiers</b>" as FS #FFE9EC
participant "<b>JobService</b>" as JobService #E6F4FF

== Demarrage ==
Utilisateur -> UI : Selectionne un job (type Differential)
UI -> BackupService : Run(job)

alt Job inactif / blocage service / deja en cours
  BackupService --> UI : BackupResultDto immediat (erreur/skipped)
else Demarrage accepte
  BackupService -> StateWriter : Enregistre un instantane (job en cours)
  BackupService -> UI : StateChanged(Running) [event]
  BackupService -> ThreadPool : Lance la sauvegarde en tache de fond
  BackupService --> UI : BackupResultDto ("Job started asynchronously.")

  == Execution differenielle (fond) ==
  ThreadPool -> BackupEngine : Demarre l execution de la sauvegarde
  BackupEngine -> Detector : Refait un controle logiciel metier avant de commencer

  alt Blocage metier au start moteur
    BackupEngine -> Logger : Write("job.start.blocked.businesssoftware")
    BackupEngine -> Logger : Ecrit le resume d execution
    BackupEngine -> BackupService : StateChanged(Error) [event]
    BackupService -> StateWriter : Enregistre un instantane de l etat
    BackupService -> UI : StateChanged(Error) [event]
    BackupEngine --> ThreadPool : BackupResultDto erreur
    ThreadPool -> JobService : Marque le job comme execute
  else Moteur autorise
    BackupEngine -> FS : Verifie que le dossier source existe
    BackupEngine -> BackupEngine : Choisit la strategie differentielle
    BackupEngine -> FS : Liste les fichiers et calcule les totaux
    BackupEngine -> BackupService : StateChanged(Running init/totals) [event]
    BackupService -> StateWriter : Enregistre un instantane de l etat
    BackupService -> UI : StateChanged(progress) [event]

    loop Pour chaque fichier source
      opt Pause auto si logiciel metier detecte
        BackupEngine -> Detector : Verifie si le logiciel metier est ouvert
        alt Detecte
          BackupEngine -> BackupService : StateChanged(Paused) [event]
          BackupService -> StateWriter : Enregistre un instantane de l etat
          BackupService -> UI : StateChanged(Paused) [event]
          BackupEngine -> Logger : Write("job.paused")
          loop Attente fermeture logiciel
            BackupEngine -> Detector : Verifie periodiquement si le logiciel est toujours ouvert
          end
          BackupEngine -> Logger : Write("job.resumed")
          BackupEngine -> BackupService : StateChanged(Running) [event]
          BackupService -> StateWriter : Enregistre un instantane de l etat
          BackupService -> UI : StateChanged(Running) [event]
        end
      end

      BackupEngine -> Strategy : Determine si le fichier doit etre copie
      Strategy -> FS : Verifie si la cible existe
      alt Cible absente
        Strategy --> BackupEngine : true
      else Cible presente
        Strategy -> FS : Compare la taille
        alt Taille differente
          Strategy --> BackupEngine : true
        else Taille identique
          Strategy -> FS : Compare la date de modification
          alt Date identique
            Strategy --> BackupEngine : false
          else Date differente
            Strategy -> FS : Compare le contenu (hash source/cible)
            Strategy --> BackupEngine : true si le contenu est different
          end
        end
      end

      alt ShouldCopy = false
        BackupEngine -> Logger : Write("file.skipped")
      else ShouldCopy = true
        BackupEngine -> FS : Prepare le dossier de destination
        opt Dossier cree
          BackupEngine -> Logger : Write("directory.created")
        end
        BackupEngine -> FS : Copie le fichier vers la destination
        BackupEngine -> Logger : Write("file.transferred")

        opt Chiffrement requis
          alt CryptoSoft disponible
            BackupEngine -> Crypto : Chiffre le fichier copie
            Crypto --> BackupEngine : timeMs / errorCode
            BackupEngine -> Logger : Write("file.encrypted")
          else NoEncryptionService
            BackupEngine -> Logger : Write("crypto.fallback")
            BackupEngine -> Logger : Write("file.encryption.skipped")
          end
        end
      end

      BackupEngine -> BackupService : StateChanged(progress) [event]
      BackupService -> StateWriter : Enregistre un instantane de l etat
      BackupService -> UI : StateChanged(progress) [event]
    end

    == Finalisation ==
    BackupEngine -> Logger : Ecrit le resume d execution
    BackupEngine -> BackupService : StateChanged(Completed/Error) [event]
    BackupService -> StateWriter : Enregistre un instantane de l etat
    BackupService -> UI : StateChanged(final) [event]
    BackupEngine --> ThreadPool : BackupResultDto final
    ThreadPool -> JobService : Marque le job comme execute
  end
end

note over UI,ThreadPool
La vue recoit un resultat de lancement immediat.
La fin reelle est publiee via StateChanged + logs.
end note

UI -> Utilisateur : Affiche lancement puis progression

@enduml
