@startuml EasySave_Backup_Differential

' ============================================
' CONFIGURATION
' ============================================
skinparam shadowing false
skinparam dpi 170
skinparam backgroundColor #FFFFFF

skinparam sequence {
  MessageAlign center
  ArrowColor #2F3A4A
  ArrowThickness 1
  LifeLineBorderColor #B7C0CE
  LifeLineBackgroundColor #F7F9FC

  ParticipantBorderColor #2F3A4A
  ParticipantBackgroundColor #EEF3FF
  ParticipantFontColor #1C2A3A
  ParticipantFontStyle bold

  ActorBorderColor #2F3A4A
  ActorBackgroundColor #FFF4E5

  BoxBorderColor #9FB1C9
  BoxBackgroundColor #F7F9FC

  GroupBorderColor #9FB1C9
  GroupBackgroundColor #F7F9FC
}

title <b>EasySave</b>\n<i>Sequence sauvegarde differentielle (V2: blocage uniquement logiciel metier + CryptoSoft)</i>

' -------------------- ACTEURS / PARTICIPANTS --------------------
actor Utilisateur #FFF4E5

participant "<b>Interface</b>\n(Console ou GUI)" as UI #EEF3FF
participant "<b>BackupService</b>" as BackupService #E9F7EF
participant "<b>BusinessSoftwareDetector</b>" as Detector #FFF8E1
participant "<b>BackupEngine</b>" as BackupEngine #F3E8FF
participant "<b>DifferentialCopyStrategy</b>" as Strategy #E6F4FF
participant "<b>ICryptoService</b>\n(CryptoSoftProcess / NoEncryption)" as Crypto #E8F5E9
participant "<b>Logger</b>" as Logger #F7F9FC
participant "<b>Systeme de fichiers</b>" as FS #FFE9EC

' -------------------- FLUX --------------------
== Demarrage ==
Utilisateur -> UI : Selectionne un job mode differentiel
UI -> BackupService : Run(job)

BackupService -> Detector : IsRunning(processName config)
alt Logiciel metier actif
    BackupService -> Logger : Log "job.start.blocked.businesssoftware"
    BackupService --> UI : Retourne erreur de blocage
else Aucun blocage
    BackupService -> BackupEngine : Run(job)
end
  BackupEngine -> Detector : ValidateNotRunning(processName config)
  alt Logiciel metier detecte
    BackupEngine -> Logger : Log blocage + summary
    BackupEngine --> BackupService : Retourne erreur
    BackupService --> UI : Retourne erreur
  else Execution differenielle
    BackupEngine -> BackupEngine : Selectionne DifferentialCopyStrategy
    BackupEngine -> FS : Enumere fichiers source + calcule totaux

    == Evaluation des fichiers ==
    loop Pour chaque fichier source
      BackupEngine -> Strategy : ShouldCopy(sourcePath, targetPath)

      Strategy -> FS : Verifie existence cible
      alt Cible absente
        Strategy --> BackupEngine : true (copier)
      else Cible presente
        Strategy -> FS : Compare taille
        alt Taille differente
          Strategy --> BackupEngine : true (copier)
        else Taille identique
          Strategy -> FS : Compare LastWriteTimeUtc
          alt Date identique
            Strategy --> BackupEngine : false (skip)
          else Date differente
            Strategy -> FS : ComputeHash(source) et ComputeHash(target)
            Strategy --> BackupEngine : copier si hash different
          end
        end
      end

      alt Doit copier
        BackupEngine -> FS : EnsureTargetDirectory + CopyFile
        BackupEngine -> Logger : Log transfert

        opt Chiffrement requis\n(config active + extension eligible)
          alt CryptoSoft disponible
            BackupEngine -> Crypto : EncryptFileAsync(target, key)
            Crypto --> BackupEngine : encryptionTimeMs / code erreur
            alt Echec chiffrement
              BackupEngine -> BackupEngine : Ajoute erreur au resultat
              BackupEngine -> Logger : Log "file.encrypted" (failure)
              BackupEngine -> BackupEngine : Continue la sauvegarde (pas de blocage)
            else Chiffrement OK
              BackupEngine -> Logger : Log "file.encrypted" (success)
            end
          else CryptoSoft absent
            BackupEngine -> Logger : Log "crypto.fallback"
            BackupEngine -> Logger : Log "file.encryption.skipped"
            BackupEngine -> BackupEngine : Continue la sauvegarde (pas de blocage)
          end
        end
      else Ne doit pas copier
        BackupEngine -> Logger : Log "file.skipped"
      end

      BackupEngine -> Detector : IsRunning(processName config)
      alt Logiciel metier detecte en cours
        BackupEngine -> Logger : Log "job.stopped.businesssoftware"
        break
      end
    end

    == Finalisation ==
    BackupEngine -> Logger : WriteSummaryLog(job.summary)
    BackupEngine --> BackupService : Retourne BackupResultDto
    BackupService --> UI : Retourne resultat
  end
end

UI -> Utilisateur : Affiche le resume

@enduml
